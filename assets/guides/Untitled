  {
    "id": "summer-heat-stress",
    "title": "Summer Heat Stress Prevention",
    "category": "Seasonal care (heat/cold)",
    "difficulty": "Intermediate",
    "season": "Hot season",
    "readMinutes": 5,
    "tags": ["summer", "heat", "hydration", "ventilation"],
    "updatedAt": "2026-03-15T00:00:00.000Z",
    "blocks": [
      {
        "type": "paragraph",
        "text": "Egg production often declines in high heat. Focus on airflow, cool water, and shade during the hottest hours."
      },
      {
        "type": "warning",
        "title": "Emergency signs",
        "text": "Panting with wings spread and lethargy can indicate heat stress. Immediate cooling action is required."
      },
      {
        "type": "checklist",
        "title": "Heat plan",
        "items": [
          "Refill cool water several times per day",
          "Add shade cloth over exposed runs",
          "Increase coop airflow with safe fans",
          "Offer wet mash or water-rich treats in evening"
        ]
      }
    ]
  },
